<script>
"use strict";
const DATA = __DATA__;

// ---- palette (validated sequential blue ramp; see dataviz reference) -------
const RAMP = ["#cde2fb","#b7d3f6","#9ec5f4","#86b6ef","#6da7ec","#5598e7",
              "#3987e5","#2a78d6","#256abf","#1c5cab","#184f95","#104281","#0d366b"];
const darkQuery = matchMedia("(prefers-color-scheme: dark)");
let themeMode = "auto";  // "auto" (follow system) | "light" | "dark"
function effectiveDark() {
  return themeMode === "dark" || (themeMode === "auto" && darkQuery.matches);
}
let theme = {};
function readTheme() {
  const cs = getComputedStyle(document.documentElement);
  theme = {
    dark: effectiveDark(),
    surface: cs.getPropertyValue("--surface").trim(),
    ink: cs.getPropertyValue("--ink").trim(),
    ink2: cs.getPropertyValue("--ink-2").trim(),
    muted: cs.getPropertyValue("--muted").trim(),
    hairline: cs.getPropertyValue("--hairline").trim(),
  };
}
function hexRGB(h) {
  return [parseInt(h.slice(1,3),16), parseInt(h.slice(3,5),16), parseInt(h.slice(5,7),16)];
}
// t in [0,1] -> ramp color. On the dark surface the dark end recedes, so the
// mapping flips: more work = lighter/brighter there, darker on light.
function rampColor(t) {
  if (theme.dark) t = 1 - t;
  const x = Math.max(0, Math.min(1, t)) * (RAMP.length - 1);
  const i = Math.min(RAMP.length - 2, Math.floor(x)), fr = x - i;
  const a = hexRGB(RAMP[i]), b = hexRGB(RAMP[i+1]);
  return "rgb(" + Math.round(a[0]+(b[0]-a[0])*fr) + "," +
                  Math.round(a[1]+(b[1]-a[1])*fr) + "," +
                  Math.round(a[2]+(b[2]-a[2])*fr) + ")";
}

// ---- formatting -------------------------------------------------------------
function fmtNs(ns) {
  if (ns == null) return "?";
  if (ns < 1e3) return Math.round(ns) + " ns";
  if (ns < 1e6) return (ns/1e3).toFixed(1) + " µs";
  if (ns < 1e9) return (ns/1e6).toFixed(2) + " ms";
  return (ns/1e9).toFixed(3) + " s";
}
function fmtCount(n) { return n.toLocaleString("en-US"); }

// ---- layout (world coordinates) ---------------------------------------------
const LEAF_W = 14, GAP = 12, FORK_H = 20, JOIN_H = 20, NODE_R = 3.5;
let yScale = 1;  // y-axis scale slider: stretches/squashes box heights
function timeH(ns) {
  return (ns <= 0 ? 2 : 4 + 18 * Math.log2(1 + ns / 5e4)) * yScale;
}

function layout(n) {
  if (!n.b) {
    n._w = LEAF_W;
    n._h = Math.max(6 * yScale, timeH(n.w));
    return;
  }
  let h = 0, w = LEAF_W, mxc = 0;
  for (let i = 0; i < n.b.length; i++) {
    h += timeH(n.g[i]);
    const l = n.b[i][0], r = n.b[i][1];
    layout(l); layout(r);
    h += (FORK_H + JOIN_H) * yScale + Math.max(l._h, r._h);
    w = Math.max(w, l._w + GAP + r._w);
    mxc = Math.max(mxc, l._w, r._w);
  }
  h += timeH(n.g[n.b.length]);
  n._w = w; n._h = h;
  n._mxc = mxc;  // widest immediate child, for level-of-detail
}

// ---- viewer ------------------------------------------------------------------
const canvas = document.getElementById("c");
const ctx = canvas.getContext("2d");
const tooltip = document.getElementById("tooltip");
let view = { x: 0, y: 0, k: 1 };      // world -> screen: s = (w - view.xy) * k
let round = null;                     // current round object
let colorDomain = { lo: 1e4, hi: 1e9 };
let hatch = null;

function makeHatch() {
  const p = document.createElement("canvas");
  p.width = p.height = 8;
  const g = p.getContext("2d");
  g.strokeStyle = theme.dark ? "rgba(13,13,13,0.55)" : "rgba(252,252,251,0.75)";
  g.lineWidth = 1.6;
  g.beginPath();
  for (let o = -8; o <= 16; o += 4) { g.moveTo(o, 8); g.lineTo(o + 8, 0); }
  g.stroke();
  hatch = ctx.createPattern(p, "repeat");
}

function colorForNs(ns) {
  const lo = Math.log(colorDomain.lo), hi = Math.log(colorDomain.hi);
  const t = (Math.log(Math.max(ns, 1)) - lo) / Math.max(hi - lo, 1e-9);
  return rampColor(0.08 + 0.92 * Math.max(0, Math.min(1, t)));
}

function sx(wx) { return (wx - view.x) * view.k; }
function sy(wy) { return (wy - view.y) * view.k; }

let W = 0, H = 0;  // canvas CSS size
function resize() {
  const dpr = devicePixelRatio || 1;
  W = canvas.clientWidth; H = canvas.clientHeight;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  draw();
}

// Level of detail: a subtree expands only when its box is reasonably large
// AND its widest immediate child would be at least CHILD_PX wide on screen
// -- otherwise it draws as one aggregate glyph. Dense fans of uniformly
// small children (where hovering is ambiguous) therefore collapse eagerly
// and the collapse propagates upward as you zoom out, while a large subtree
// with one small sibling leaf still expands.
const LOD_H = 24, LOD_W = 10, CHILD_PX = 10;
function tooSmall(n) {
  return n._h * view.k < LOD_H || n._w * view.k < LOD_W ||
         n._mxc * view.k < CHILD_PX;
}

function roundRect(x, y, w, h, r) {
  r = Math.min(r, w / 2, h / 2);
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.arcTo(x + w, y, x + w, y + h, r);
  ctx.arcTo(x + w, y + h, x, y + h, r);
  ctx.arcTo(x, y + h, x, y, r);
  ctx.arcTo(x, y, x + w, y, r);
  ctx.closePath();
}

// frac in [0,1]: how much of this element has "happened" at the current
// playback time. 1 = fully drawn (the static view); partial glyphs fill
// top-down, matching time flowing down the page.
function drawGlyph(n, wx, wy, hatched, frac) {
  const x = sx(wx), y = sy(wy);
  const w = Math.max(n._w * view.k, 2.5), h = Math.max(n._h * view.k, 2.5);
  roundRect(x, y, w, h, 3);
  if (frac >= 1) {
    ctx.fillStyle = colorForNs(n.w);
    ctx.fill();
    if (hatched && w > 6 && h > 6) { ctx.fillStyle = hatch; ctx.fill(); }
    ctx.strokeStyle = theme.hairline;
    ctx.lineWidth = 1;
  } else {
    ctx.save();
    ctx.clip();
    ctx.fillStyle = colorForNs(n.w);
    ctx.fillRect(x, y, w, h * frac);
    if (hatched && w > 6 && h > 6) { ctx.fillStyle = hatch; ctx.fillRect(x, y, w, h * frac); }
    ctx.restore();
    roundRect(x, y, w, h, 3);
    ctx.strokeStyle = frac > 0 ? theme.ink2 : theme.hairline;  // active frontier
    ctx.lineWidth = frac > 0 ? 1.5 : 1;
  }
  ctx.stroke();
}

function drawSegment(cx, y0, y1, ns, frac) {
  const x = sx(cx), a = sy(y0), b = sy(y1);
  const bb = a + (b - a) * frac;
  if (bb - a < 0.5) return;
  const w = Math.max(2, Math.min(8, 5 * Math.sqrt(view.k)));
  ctx.fillStyle = colorForNs(ns);
  roundRect(x - w / 2, a, w, bb - a, w / 2);
  ctx.fill();
}

function drawNodeDot(cx, cy) {
  const r = Math.max(1.5, Math.min(5, NODE_R * Math.sqrt(view.k)));
  ctx.beginPath();
  ctx.arc(sx(cx), sy(cy), r, 0, 2 * Math.PI);
  ctx.fillStyle = theme.ink2;
  ctx.fill();
}

let edgeScale = 1;  // edge thickness slider: multiplies the zoom-adaptive width

function drawEdge(x0, y0, x1, y1) {
  ctx.beginPath();
  ctx.moveTo(sx(x0), sy(y0));
  const my = (y0 + y1) / 2;
  ctx.bezierCurveTo(sx(x0), sy(my), sx(x1), sy(my), sx(x1), sy(y1));
  ctx.strokeStyle = theme.muted;
  ctx.lineWidth = Math.max(0.75, Math.min(2, 1.2 * Math.sqrt(view.k))) * edgeScale;
  ctx.stroke();
}

function offscreen(wx, wy, ww, wh) {
  return sx(wx + ww) < -20 || sx(wx) > W + 20 || sy(wy + wh) < -20 || sy(wy) > H + 20;
}

// Playback: playT is the current replay time in ns since the round start,
// or null for the static (everything drawn) view. Each element carries a
// wall-clock window [t0, t1]: blocks use their recorded fork/join times,
// segments span the gap between the surrounding joins/forks, and children
// inherit their block's window.
let playT = null;

function progress(t0, t1) {
  if (playT === null) return 1;
  if (playT <= t0) return 0;
  if (t1 <= t0 || playT >= t1) return 1;
  return (playT - t0) / (t1 - t0);
}

function drawTask(n, wx, wy, t0, t1) {
  if (offscreen(wx, wy, n._w, n._h)) return;
  if (playT !== null && playT <= t0) return;
  if (!n.b) { drawGlyph(n, wx + n._w / 2 - LEAF_W / 2, wy, n.f > 0, progress(t0, t1)); return; }
  if (tooSmall(n)) { drawGlyph(n, wx, wy, false, progress(t0, t1)); return; }

  const cx = wx + n._w / 2;
  let y = wy;
  let prev = t0;
  for (let i = 0; i < n.b.length; i++) {
    const bft = n.b[i][2] == null ? prev : n.b[i][2];
    const bjt = n.b[i][3] == null ? bft : n.b[i][3];
    const segH = timeH(n.g[i]);
    drawSegment(cx, y, y + segH, n.g[i], progress(prev, bft));
    y += segH;
    if (playT !== null && playT <= bft) return;  // rest of the chain is later
    const l = n.b[i][0], r = n.b[i][1];
    const tot = l._w + GAP + r._w;
    const lx = cx - tot / 2, rx = lx + l._w + GAP;
    const childTop = y + FORK_H * yScale;
    const inner = Math.max(l._h, r._h);
    const joinY = childTop + inner + JOIN_H * yScale;
    drawEdge(cx, y + NODE_R, lx + l._w / 2, childTop);
    drawEdge(cx, y + NODE_R, rx + r._w / 2, childTop);
    const joined = playT === null || playT >= bjt;
    if (joined) {
      drawEdge(lx + l._w / 2, childTop + l._h, cx, joinY - NODE_R);
      drawEdge(rx + r._w / 2, childTop + r._h, cx, joinY - NODE_R);
    }
    drawNodeDot(cx, y + NODE_R);
    drawTask(l, lx, childTop, bft, bjt);
    drawTask(r, rx, childTop, bft, bjt);
    if (joined) drawNodeDot(cx, joinY - NODE_R);
    y = joinY;
    prev = bjt;
  }
  const segH = timeH(n.g[n.b.length]);
  drawSegment(cx, y, y + segH, n.g[n.b.length], progress(prev, t1));
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  if (!round) return;
  drawTask(round.tree, 0, 0, 0, round.dur == null ? 0 : round.dur);
}

// ---- hit testing --------------------------------------------------------------
function hitTask(n, wx, wy, mx, my) {
  if (mx < wx || mx > wx + n._w || my < wy || my > wy + n._h) return null;
  if (!n.b) return { n: n, kind: n.f > 0 ? "collapsed" : "leaf" };
  if (tooSmall(n)) return { n: n, kind: "lod" };
  const cx = wx + n._w / 2;
  let y = wy;
  for (let i = 0; i < n.b.length; i++) {
    const segH = timeH(n.g[i]);
    if (my < y + segH) {
      return Math.abs(mx - cx) < 8 / view.k
        ? { n: n, kind: "seg", ns: n.g[i] } : { n: n, kind: "task" };
    }
    y += segH;
    const l = n.b[i][0], r = n.b[i][1];
    const tot = l._w + GAP + r._w;
    const lx = cx - tot / 2, rx = lx + l._w + GAP;
    const childTop = y + FORK_H * yScale;
    const inner = Math.max(l._h, r._h);
    const joinY = childTop + inner + JOIN_H * yScale;
    if (my < joinY) {
      const hl = hitTask(l, lx, childTop, mx, my);
      if (hl) return hl;
      const hr = hitTask(r, rx, childTop, mx, my);
      if (hr) return hr;
      return { n: n, kind: "task" };
    }
    y = joinY;
  }
  const segH = timeH(n.g[n.b.length]);
  if (my < y + segH && Math.abs(mx - cx) < 8 / view.k)
    return { n: n, kind: "seg", ns: n.g[n.b.length] };
  return { n: n, kind: "task" };
}

function tooltipHTML(hit) {
  const n = hit.n;
  const kinds = {
    collapsed: "Collapsed subtree (below trace cutoff)",
    leaf: "Sequential leaf",
    lod: "Subtree — zoom in for detail",
    seg: "Sequential segment",
    task: "Subtree",
  };
  let rows = "";
  function row(k, v) { rows += "<tr><td>" + k + "</td><td>" + v + "</td></tr>"; }
  if (hit.kind === "seg") {
    row("duration", fmtNs(hit.ns));
  } else {
    row("work", fmtNs(n.w));
    row("forks", fmtCount(n.f));
    if (n.f > 0) row("avg work / fork", fmtNs(n.w / n.f));
  }
  return '<div class="tt-kind">' + kinds[hit.kind] + "</div><table>" + rows + "</table>";
}

// ---- interaction ----------------------------------------------------------------
let panning = false, px = 0, py = 0, moved = false;
canvas.addEventListener("pointerdown", e => {
  panning = true; moved = false; px = e.clientX; py = e.clientY;
  canvas.classList.add("panning");
  canvas.setPointerCapture(e.pointerId);
});
canvas.addEventListener("pointermove", e => {
  const rect = canvas.getBoundingClientRect();
  if (panning) {
    const dx = e.clientX - px, dy = e.clientY - py;
    if (Math.abs(dx) + Math.abs(dy) > 2) moved = true;
    view.x -= dx / view.k; view.y -= dy / view.k;
    px = e.clientX; py = e.clientY;
    tooltip.style.display = "none";
    draw();
    return;
  }
  if (!round) return;
  const mx = (e.clientX - rect.left) / view.k + view.x;
  const my = (e.clientY - rect.top) / view.k + view.y;
  const hit = hitTask(round.tree, 0, 0, mx, my);
  if (hit) {
    tooltip.innerHTML = tooltipHTML(hit);
    tooltip.style.display = "block";
    const tx = Math.min(e.clientX - rect.left + 14, W - tooltip.offsetWidth - 8);
    const ty = Math.min(e.clientY - rect.top + 14, H - tooltip.offsetHeight - 8);
    tooltip.style.left = tx + "px";
    tooltip.style.top = ty + "px";
  } else {
    tooltip.style.display = "none";
  }
});
canvas.addEventListener("pointerup", () => {
  panning = false;
  canvas.classList.remove("panning");
});
canvas.addEventListener("pointerleave", () => { tooltip.style.display = "none"; });
canvas.addEventListener("wheel", e => {
  e.preventDefault();
  const rect = canvas.getBoundingClientRect();
  const mx = e.clientX - rect.left, my = e.clientY - rect.top;
  const f = Math.exp(-e.deltaY * 0.0016);
  const k2 = Math.max(1e-4, Math.min(1e4, view.k * f));
  view.x += mx / view.k - mx / k2;
  view.y += my / view.k - my / k2;
  view.k = k2;
  tooltip.style.display = "none";
  draw();
}, { passive: false });

function fit() {
  if (!round) return;
  const t = round.tree;
  const k = Math.min(W / (t._w + 60), H / (t._h + 60));
  view.k = Math.max(1e-4, Math.min(1e4, k));
  view.x = t._w / 2 - W / 2 / view.k;
  view.y = t._h / 2 - H / 2 / view.k;
  draw();
}
document.getElementById("fit").addEventListener("click", fit);

document.getElementById("ewidth").addEventListener("input", e => {
  edgeScale = Math.pow(2, +e.target.value);
  draw();
});

document.getElementById("yscale").addEventListener("input", e => {
  const oldH = round ? round.tree._h : 1;
  yScale = Math.pow(2, +e.target.value);
  if (!round) return;
  layout(round.tree);
  // keep the world point at the vertical screen center roughly in place
  const ratio = round.tree._h / oldH;
  const cy = view.y + (H / 2) / view.k;
  view.y = cy * ratio - (H / 2) / view.k;
  draw();
});

// ---- playback -----------------------------------------------------------------
// Replays the recorded execution in real time, slowed down by `speed`
// (default 10x; the slider is log-scale 1x..1000x).
const playBtn = document.getElementById("play");
const rewindBtn = document.getElementById("rewind");
const scrub = document.getElementById("scrub");
const clockEl = document.getElementById("clock");
const speedEl = document.getElementById("speed");
const speedLabel = document.getElementById("speedLabel");
let playing = false, speed = 10, lastFrame = 0;

function speedFromSlider() {
  speed = Math.pow(10, +speedEl.value);
  const s = speed >= 100 ? Math.round(speed) : speed.toFixed(1);
  speedLabel.textContent = s + "× slower";
}
speedEl.addEventListener("input", speedFromSlider);

function updatePlaybackUI() {
  playBtn.innerHTML = playing ? "&#9646;&#9646;" : "&#9654;";
  const dur = round && round.dur != null ? round.dur : 0;
  const t = playT === null ? dur : playT;
  scrub.value = dur > 0 ? Math.round(1000 * t / dur) : 0;
  clockEl.innerHTML = "<b>" + fmtNs(t) + "</b> / " + fmtNs(dur);
}

function frame(now) {
  if (!playing) return;
  playT += (now - lastFrame) * 1e6 / speed;  // ms of real time -> ns of trace time
  lastFrame = now;
  if (playT >= round.dur) { playT = round.dur; playing = false; }
  updatePlaybackUI();
  draw();
  if (playing) requestAnimationFrame(frame);
}

function togglePlay() {
  if (!round || round.dur == null || round.dur <= 0) return;
  if (playing) {
    playing = false;
  } else {
    if (playT === null || playT >= round.dur) playT = 0;
    playing = true;
    lastFrame = performance.now();
    requestAnimationFrame(frame);
  }
  updatePlaybackUI();
  draw();
}
playBtn.addEventListener("click", togglePlay);
rewindBtn.addEventListener("click", () => {
  playing = false; playT = null;
  updatePlaybackUI();
  draw();
});
scrub.addEventListener("input", () => {
  if (!round || round.dur == null) return;
  playing = false;
  playT = round.dur * (+scrub.value) / 1000;
  if (playT >= round.dur) playT = null;
  updatePlaybackUI();
  draw();
});
addEventListener("keydown", e => {
  if (e.code === "Space" && e.target.tagName !== "INPUT" && e.target.tagName !== "SELECT") {
    e.preventDefault();
    togglePlay();
  }
});

// ---- rounds ---------------------------------------------------------------------
const sel = document.getElementById("round");
DATA.forEach((r, i) => {
  const o = document.createElement("option");
  o.value = i;
  o.textContent = r.label + " — " + fmtNs(r.dur) + ", " +
                  fmtCount(r.records) + " records";
  sel.appendChild(o);
});
function selectRound(i) {
  round = DATA[i];
  layout(round.tree);
  colorDomain = { lo: 2e4, hi: Math.max(round.tree.w, 1e5) };
  playing = false;
  playT = null;
  document.getElementById("playbar").classList.toggle(
    "hidden", round.dur == null || round.dur <= 0);
  speedFromSlider();
  updatePlaybackUI();
  const st = document.getElementById("stats");
  st.innerHTML =
    (round.threads != null ? "<b>" + round.threads + "</b> threads &middot; " : "") +
    "<b>" + fmtNs(round.dur) + "</b> &middot; " +
    fmtCount(round.records) + " joins traced";
  fit();
}
sel.addEventListener("change", () => selectRound(+sel.value));

// default: the augment round with the most work (fall back to any partition)
let best = 0, bestAug = -1;
DATA.forEach((r, i) => {
  if (r.tree.w > DATA[best].tree.w) best = i;
  const aug = r.label.startsWith("round");
  if (aug && (bestAug < 0 || r.tree.w > DATA[bestAug].tree.w)) bestAug = i;
});
if (bestAug >= 0) best = bestAug;
sel.value = best;

// legend ramp
function paintLegend() {
  const stops = [];
  for (let i = 0; i <= 10; i++) stops.push(rampColor(0.08 + 0.92 * i / 10));
  document.getElementById("rampBox").style.background =
    "linear-gradient(to right," + stops.join(",") + ")";
  document.getElementById("hatchBox").style.background = rampColor(0.6);
}

function applyTheme() {
  readTheme();
  makeHatch();
  paintLegend();
  draw();
}
darkQuery.addEventListener("change", applyTheme);

// theme toggle: follow system -> light -> dark -> follow system
const themeBtn = document.getElementById("themeBtn");
const THEME_LABELS = { auto: "◑ auto", light: "☀︎ light", dark: "☾ dark" };
function setThemeMode(m) {
  themeMode = m;
  if (m === "auto") document.documentElement.removeAttribute("data-theme");
  else document.documentElement.setAttribute("data-theme", m);
  themeBtn.textContent = THEME_LABELS[m];
  applyTheme();
}
themeBtn.addEventListener("click", () => {
  setThemeMode(themeMode === "auto" ? "light" : themeMode === "light" ? "dark" : "auto");
});
setThemeMode("auto");

readTheme();
makeHatch();
paintLegend();
new ResizeObserver(resize).observe(canvas);
resize();
selectRound(best);
</script>
</body>
</html>
"""

