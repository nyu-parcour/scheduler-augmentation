#!/usr/bin/env python3
"""Interactive visualization of a parlay fork-join trace.

Usage:  ./visualize <trace-file> [-o out.html] [--no-open]

Reads the trace produced by a -DPARLAY_AUG binary (see
include/parlay/internal/vertex.h for the format), reconstructs the
series-parallel computation graph from the depa tids, and writes a
self-contained interactive HTML page (pan/zoom, level-of-detail).
"""

import argparse
import json
import os
import sys
import webbrowser

# --- depa tid arithmetic (mirror of include/parlay/internal/depa.h) ---------

TREE_DEPTH_BITS = 6
TREE_DEPTH_MASK = (1 << TREE_DEPTH_BITS) - 1


def fork_tids(path, depth):
    h = depth & TREE_DEPTH_MASK
    d = depth + (1 << TREE_DEPTH_BITS) + 1
    left = (path & ~(1 << h)) | (1 << (h + 1))
    right = (path | (1 << h)) | (1 << (h + 1))
    return (left, d), (right, d)


def dag_depth(tid):
    return tid[1] >> TREE_DEPTH_BITS


def task_key(tid):
    """Identity of the task a tid belongs to: as a task forks and joins, its
    tree depth and path bits below the tree depth stay invariant."""
    path, depth = tid
    d = depth & TREE_DEPTH_MASK
    return (d, path & ((1 << (d + 1)) - 1))


# --- trace parsing -----------------------------------------------------------

def new_round(label):
    return {"label": label, "records": {}, "root": None, "dups": 0,
            "begin_ts": None}


def parse_trace(path):
    """Split the trace into rounds (one per augment call, plus anything
    traced outside augment, e.g. warmup)."""
    rounds = []
    cur = new_round("outside augment (warmup)")
    n_between = 0

    def close(nxt):
        nonlocal cur
        if cur["records"] or cur["root"] is not None:
            rounds.append(cur)
        cur = nxt

    with open(path) as f:
        for lineno, line in enumerate(f, 1):
            parts = line.split()
            if not parts:
                continue
            kind = parts[0]
            if kind == "J":
                if len(parts) != 12:
                    sys.exit("error: line %d has %d fields, expected 12 -- "
                             "stale trace? rebuild the .aug binary and rerun"
                             % (lineno, len(parts)))
                p = (int(parts[1], 16), int(parts[2]))
                rec = {
                    "j": (int(parts[3], 16), int(parts[4])),
                    "ft": int(parts[5]), "jt": int(parts[6]),
                    "pw": int(parts[7]),
                    "lf": int(parts[8]), "lw": int(parts[9]),
                    "rf": int(parts[10]), "rw": int(parts[11]),
                }
                if p in cur["records"]:
                    cur["dups"] += 1
                cur["records"][p] = rec
            elif kind == "A":
                nxt = new_round("round " + parts[1])
                nxt["begin_ts"] = int(parts[2])
                close(nxt)
            elif kind == "R":
                cur["root"] = {
                    "threads": int(parts[1]),
                    "f": int(parts[2]),
                    "w": int(parts[3]),
                    "ts": int(parts[4]),
                }
                n_between += 1
                close(new_round("outside augment (#%d)" % n_between))
            else:
                print("warning: unrecognized line %d: %r" % (lineno, line.rstrip()),
                      file=sys.stderr)
    close(None)
    return rounds


# --- series-parallel tree reconstruction -------------------------------------

def build_task(birth, records, index, total, bound=None, final_tid=None):
    """Follow the chain of join records for the task born with tid `birth`.
    `total` = (forks, work) of this task's whole subtree, if known (from the
    parent's record, or from the R record for the root).
    If `final_tid` is a one-element list, the tid at the end of the chain is
    written into it (the root vertex keeps this tid into the next partition).

    A task's chain can have gaps: a below-cutoff join is not emitted, but a
    later join of the same task may be. `index` maps task_key -> keys sorted
    by dag depth, so a broken chain resumes at the next record of the same
    task with dag depth in [current, bound). The gap's hidden work folds into
    the sequential segment (pw is cumulative). `bound` is the dag depth of
    the enclosing join, which separates this task from later same-key
    incarnations (a sibling from a later fork of the same parent).

    Returns a node:
      task:  {w, f, g: [segment ns...], b: [[left, right, ft, jt], ...]}
             (len(g) == len(b) + 1; segments interleave the fork-join blocks;
             ft/jt are the block's fork/join wall-clock times relative to the
             round start)
      leaf:  {w, f}  (a subtree below the trace cutoff, collapsed;
             f == 0 means it ran purely sequentially)
    """
    segs = []
    blocks = []
    consumed = 0  # parent's cumulative work at the last join
    cur = birth
    while True:
        if cur not in records:
            nxt = resume_chain(cur, records, index, bound)
            if nxt is None:
                break
            cur = nxt
        rec = records.pop(cur)
        segs.append(max(rec["pw"] - consumed, 0))
        lb, rb = fork_tids(*cur)
        child_bound = dag_depth(rec["j"])
        left = build_task(lb, records, index, (rec["lf"], rec["lw"]), child_bound)
        right = build_task(rb, records, index, (rec["rf"], rec["rw"]), child_bound)
        blocks.append([left, right, rec["ft"], rec["jt"]])
        consumed = rec["pw"] + rec["lw"] + rec["rw"]
        cur = rec["j"]

    if final_tid is not None:
        final_tid[0] = cur

    if total is not None:
        forks, work = total
    else:
        # No R record for this partition: estimate totals from what we saw.
        forks = sum(b[0]["f"] + b[1]["f"] + 1 for b in blocks)
        work = consumed

    if not blocks:
        return {"w": work, "f": forks}

    segs.append(max(work - consumed, 0))
    return {"w": work, "f": forks, "g": segs, "b": blocks}


def resume_chain(cur, records, index, bound):
    """Find the next unconsumed record of cur's task: same task_key, dag
    depth in [dag_depth(cur), bound). Chains have strictly increasing dag
    depth, and everything belonging to a later same-key incarnation sits at
    dag depth >= bound."""
    best = None
    for key in index.get(task_key(cur), ()):
        d = dag_depth(key)
        if d < dag_depth(cur) or (bound is not None and d >= bound):
            continue
        if key not in records:
            continue
        if best is None or d < dag_depth(best):
            best = key
    return best


def build_round(rnd, birth):
    """`birth` is the root vertex's tid at the start of this partition:
    (1, 0) after each augment reset, or wherever the previous partition's
    chain ended otherwise. Returns (round-dict, final-tid)."""
    records = dict(rnd["records"])
    n_records = len(records)
    index = {}
    for key in records:
        index.setdefault(task_key(key), []).append(key)
    root_info = rnd["root"]
    total = (root_info["f"], root_info["w"]) if root_info else None
    final = [birth]
    tree = build_task(birth, records, index, total, None, final)

    # Normalize block timestamps to the round start; dur is the round's
    # wall-clock length.
    stamps = [t for r in rnd["records"].values() for t in (r["ft"], r["jt"])]
    t0 = rnd["begin_ts"] if rnd["begin_ts"] is not None else (
        min(stamps) if stamps else None)
    end = root_info["ts"] if root_info else (max(stamps) if stamps else None)
    dur = end - t0 if t0 is not None and end is not None else None
    if t0 is not None:
        shift_times(tree, t0)

    return {
        "label": rnd["label"],
        "threads": root_info["threads"] if root_info else None,
        "tree": tree,
        "dur": dur,
        "records": n_records,
        "orphans": len(records),
        "dups": rnd["dups"],
    }, final[0]


def shift_times(node, t0):
    for b in node.get("b", ()):
        b[2] = max(b[2] - t0, 0)
        b[3] = max(b[3] - t0, 0)
        shift_times(b[0], t0)
        shift_times(b[1], t0)


# --- HTML generation ----------------------------------------------------------

def make_html(title, rounds_json):
    html = HTML_TEMPLATE
    html = html.replace("__TITLE__", title)
    html = html.replace("__DATA__", rounds_json.replace("</", "<\\/"))
    return html


def main():
    ap = argparse.ArgumentParser(description=__doc__.split("\n")[0])
    ap.add_argument("trace", help="trace file produced by a PARLAY_AUG binary")
    ap.add_argument("-o", "--output", help="output HTML file "
                    "(default: <trace>.html)")
    ap.add_argument("--no-open", action="store_true",
                    help="don't open the result in a web browser")
    args = ap.parse_args()

    rounds = parse_trace(args.trace)
    if not rounds:
        print("error: no trace records found in %s" % args.trace, file=sys.stderr)
        sys.exit(1)

    built = []
    tid = (1, 0)
    for r in rounds:
        if r["label"].startswith("round"):
            tid = (1, 0)  # augment resets the root vertex
        b, tid = build_round(r, tid)
        built.append(b)
    for b in built:
        if b["orphans"]:
            print("warning: %s: %d join records unreachable from the root"
                  % (b["label"], b["orphans"]), file=sys.stderr)
        if b["dups"]:
            print("warning: %s: %d duplicate join records" % (b["label"], b["dups"]),
                  file=sys.stderr)

    out = args.output or (os.path.splitext(args.trace)[0] + ".html")
    title = os.path.basename(args.trace)
    data = json.dumps(built, separators=(",", ":"))
    with open(out, "w") as f:
        f.write(make_html(title, data))

    total_records = sum(b["records"] for b in built)
    print("wrote %s  (%d rounds, %d join records)" % (out, len(built), total_records))
    if not args.no_open:
        webbrowser.open("file://" + os.path.abspath(out))


